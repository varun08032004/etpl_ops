# ── Database — Supabase (separate PROJECT from the platform DB, not just a separate schema) ──
# Get this from: Supabase Dashboard > your internal-ops project > Settings > Database > Connection string
# Use the "Direct connection" string (port 5432), not the pooled one (6543/pgbouncer) —
# this server holds a long-lived pg Pool and runs multi-statement transactions for the
# ledger, which the transaction pooler doesn't support cleanly.
INTERNAL_OPS_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ── Auth ──
INTERNAL_OPS_JWT_SECRET=change-me-to-a-64-char-random-hex-string
INTERNAL_OPS_ALLOWED_ORIGIN=http://localhost:3001
ALLOW_BOOTSTRAP=false   # set true temporarily to create the first owner account, then set back to false

# ── Company GST config ──
COMPANY_STATE=Maharashtra   # your registered GST state — determines CGST+SGST vs IGST split

# ── Razorpay (payroll payouts — needs RazorpayX, a separate product from standard Razorpay Payments) ──
RAZORPAYX_KEY_ID=
RAZORPAYX_KEY_SECRET=
RAZORPAYX_ACCOUNT_NUMBER=
RAZORPAYX_WEBHOOK_SECRET=

# ── TrackPilot (attendance/activity sync) ──
TRACKPILOT_API_KEY=

INTERNAL_OPS_PORT=5050
NODE_ENV=development
